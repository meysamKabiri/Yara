APP_NAME=Yara API
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=debug
LLM=local
TRACE_ENABLED=true
RECONCILIATION=false
ANOMALY_DETECTION=false

POSTGRES_DB=yara_dev
POSTGRES_USER=yara
POSTGRES_PASSWORD=yara_password
DATABASE_URL=postgresql+psycopg://yara:yara_password@postgres:5432/yara_dev
REDIS_URL=redis://redis:6379
JWT_SECRET=dev-only-yara-secret

API_HOST_PORT=8000
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6380

YARA_IMAGE=yara-backend
IMAGE_TAG=development
INSTALL_DEV=true

OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_TIMEOUT_SECONDS=60
OLLAMA_NUM_PREDICT=120
OLLAMA_TEMPERATURE=0
RQ_QUEUES=llm_tasks
