APP_NAME=Yara API
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=warning
LLM=production
TRACE_ENABLED=true
RECONCILIATION=true
ANOMALY_DETECTION=true

POSTGRES_DB=yara_prod
POSTGRES_USER=yara_prod
POSTGRES_PASSWORD=change-me-production
DATABASE_URL=postgresql+psycopg://yara_prod:change-me-production@postgres:5432/yara_prod
REDIS_URL=redis://redis:6379
JWT_SECRET=change-me-production-jwt-secret

API_HOST_PORT=8000

YARA_IMAGE=yara-backend
IMAGE_TAG=production
INSTALL_DEV=false
PREVIOUS_IMAGE_TAG=previous

OLLAMA_BASE_URL=https://llm-provider.example.invalid
OLLAMA_MODEL=production-financial-model
OLLAMA_TIMEOUT_SECONDS=30
OLLAMA_NUM_PREDICT=120
OLLAMA_TEMPERATURE=0
RQ_QUEUES=llm_tasks
