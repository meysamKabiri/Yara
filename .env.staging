APP_NAME=Yara API
ENVIRONMENT=staging
DEBUG=false
LOG_LEVEL=info
LLM=local/restricted
TRACE_ENABLED=true
RECONCILIATION=true
ANOMALY_DETECTION=true

POSTGRES_DB=yara_staging
POSTGRES_USER=yara_staging
POSTGRES_PASSWORD=change-me-staging
DATABASE_URL=postgresql+psycopg://yara_staging:change-me-staging@postgres:5432/yara_staging
REDIS_URL=redis://redis:6379
JWT_SECRET=change-me-staging-jwt-secret

API_HOST_PORT=18080
POSTGRES_HOST_PORT=15432
REDIS_HOST_PORT=16379

YARA_IMAGE=yara-backend
IMAGE_TAG=staging
INSTALL_DEV=true

OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_TIMEOUT_SECONDS=30
OLLAMA_NUM_PREDICT=120
OLLAMA_TEMPERATURE=0
RQ_QUEUES=llm_tasks
